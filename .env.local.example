# Copy to .env.local and fill in your SMTP credentials
# Gmail example: use an App Password (not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hello@gradelevate.com
SMTP_PASS=your-app-password-here
SMTP_FROM=hello@gradelevate.com
ADMIN_EMAIL=hello@gradelevate.com
NEXT_PUBLIC_SITE_URL=https://gradelevate.com
